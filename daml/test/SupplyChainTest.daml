module SupplyChainTest where

import Daml.Script
import Main -- Assumes the main supply chain templates are in a module named `Main`.
import DA.Time (Time)

-- | A full end-to-end test of the supply chain lifecycle, from manufacturing to retail sale.
-- This script simulates the interactions between a Manufacturer, Logistics provider,
-- Customs authority, and a Retailer.
supplyChainLifecycle : Script ()
supplyChainLifecycle = script do
  -- === 1. SETUP: ALLOCATE PARTIES ===
  manufacturer <- allocatePartyWithHint "Manufacturer" (PartyIdHint "manufacturer")
  logistics <- allocatePartyWithHint "LogisticsCo" (PartyIdHint "logistics")
  customs <- allocatePartyWithHint "CustomsAuthority" (PartyIdHint "customs")
  retailer <- allocatePartyWithHint "Retailer" (PartyIdHint "retailer")

  let allObservers = [logistics, customs, retailer]

  debug "1. Parties allocated successfully."

  -- === 2. CREATION: MANUFACTURER PRODUCES ASSET ===
  let sku = "GPU-RTX-9090"
  let description = "Next Generation AI-Enabled Graphics Processor"
  initialTime <- getTime

  assetCid <- submit manufacturer do
    createCmd Asset with
      sku
      description
      manufacturer
      custodian = manufacturer
      customs
      observers = allObservers
      state = Manufactured
      lastUpdate = initialTime
      history = ["Asset created by " <> show manufacturer]

  debug $ "2. Manufacturer created asset " <> sku <> ". CID: " <> show assetCid

  -- === 3. HANDOVER: MANUFACTURER TO LOGISTICS ===
  debug "3. Manufacturer proposing transfer to Logistics provider."
  proposalCid <- submit manufacturer do
    exerciseCmd assetCid ProposeTransfer with newCustodian = logistics

  debug $ "   -> Transfer proposal created. CID: " <> show proposalCid

  debug "   -> Logistics provider accepting the transfer."
  assetCid_L1 <- submit logistics do
    exerciseCmd proposalCid AcceptTransfer

  debug $ "   -> Transfer accepted. New asset CID: " <> show assetCid_L1

  -- Verify state after transfer
  (asset_L1, _) <- fetchCid assetCid_L1
  assert (asset_L1.custodian == logistics)
  assert (asset_L1.state == InTransit)
  debug "   -> Verified: Asset is now with Logistics and InTransit."

  -- === 4. IN-TRANSIT UPDATE: ARRIVAL AT PORT ===
  debug "4. Logistics provider updating asset state to AwaitingCustoms."
  assetCid_L2 <- submit logistics do
    exerciseCmd assetCid_L1 UpdateState with
      newState = AwaitingCustoms
      logEntry = "Arrived at destination port. Awaiting customs clearance."

  -- Verify state change
  (asset_L2, _) <- fetchCid assetCid_L2
  assert (asset_L2.state == AwaitingCustoms)
  debug "   -> Verified: Asset state is AwaitingCustoms."

  -- === 5. CUSTOMS CLEARANCE ===
  debug "5. Customs Authority clearing the asset for transit."
  assetCid_L3 <- submitMulti [customs, logistics] do
    exerciseCmd assetCid_L2 ClearForTransit

  -- Verify state change
  (asset_L3, _) <- fetchCid assetCid_L3
  assert (asset_L3.state == ClearedCustoms)
  debug "   -> Verified: Asset state is ClearedCustoms."

  -- === 6. HANDOVER: LOGISTICS TO RETAILER ===
  debug "6. Logistics provider proposing transfer to Retailer."
  proposalCid2 <- submit logistics do
    exerciseCmd assetCid_L3 ProposeTransfer with newCustodian = retailer

  debug $ "   -> Transfer proposal created. CID: " <> show proposalCid2

  debug "   -> Retailer accepting the transfer."
  assetCid_R1 <- submit retailer do
    exerciseCmd proposalCid2 AcceptTransfer

  debug $ "   -> Transfer to retailer accepted. New asset CID: " <> show assetCid_R1

  -- Verify state after transfer
  (asset_R1, _) <- fetchCid assetCid_R1
  assert (asset_R1.custodian == retailer)
  assert (asset_R1.state == InTransit)
  debug "   -> Verified: Asset is now with Retailer."

  -- === 7. RETAIL OPS: RECEIVE INTO STOCK ===
  debug "7. Retailer updating asset state to InStock."
  assetCid_R2 <- submit retailer do
    exerciseCmd assetCid_R1 UpdateState with
      newState = InStock
      logEntry = "Asset scanned and received into store inventory."

  -- Verify state change
  (asset_R2, _) <- fetchCid assetCid_R2
  assert (asset_R2.state == InStock)
  debug "   -> Verified: Asset is now InStock."

  -- === 8. SALE: RETAILER SELLS ASSET ===
  debug "8. Retailer marking asset as sold, concluding its tracked lifecycle."
  submit retailer do
    exerciseCmd assetCid_R2 MarkAsSold

  -- Verify archival by confirming the contract can no longer be fetched.
  fetchCid assetCid_R2 `shouldFail` do
    pure ()
  debug "   -> Verified: Asset contract has been archived."

  debug "SUCCESS: Full supply chain lifecycle test completed."


-- | Main test suite entry point for `dpm test`.
tests = script do
  supplyChainLifecycle