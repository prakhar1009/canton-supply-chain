module SupplyChain.Test.SupplyChainTest where

import Daml.Script
import DA.Date as Date
import DA.Time as Time
import SupplyChain.Asset
import SupplyChain.Shipment
import SupplyChain.CustodyTransfer
import SupplyChain.Checkpoint

-- === Test Scenario ===
--
-- This script simulates a realistic, end-to-end supply chain workflow involving
-- four distinct parties: a Manufacturer, a Logistics provider, a Customs agency,
-- and a Retailer.
--
-- 1.  **Origination**: The Manufacturer creates a digital twin of a physical asset.
-- 2.  **Shipment Init**: The Manufacturer creates a Shipment contract, taking initial custody.
-- 3.  **Handover 1**: Manufacturer transfers custody to the Logistics provider.
-- 4.  **Checkpoint 1**: The Logistics provider records a "departed warehouse" checkpoint.
-- 5.  **Handover 2**: Logistics provider transfers custody to Customs for inspection.
-- 6.  **Checkpoint 2**: The Customs agency records a "customs cleared" checkpoint.
-- 7.  **Handover 3**: Customs transfers custody to the Retailer for final delivery.
-- 8.  **Delivery**: The Retailer marks the shipment as delivered, concluding the journey.
--
-- Each handover is a two-step proposal/acceptance process, ensuring atomic and
-- auditable transfers of responsibility.

fullSupplyChainScenario : Script ()
fullSupplyChainScenario = script do
  -- 1. SETUP: Allocate parties for the scenario
  manufacturer <- allocatePartyWithHint "Manufacturer" (PartyIdHint "manufacturer")
  logisticsProvider <- allocatePartyWithHint "LogisticsCo" (PartyIdHint "logistics")
  customsAgency <- allocatePartyWithHint "CustomsAgency" (PartyIdHint "customs")
  retailer <- allocatePartyWithHint "Retailer" (PartyIdHint "retailer")
  let allParties = [manufacturer, logisticsProvider, customsAgency, retailer]

  debug $ "Parties allocated: " <> show allParties

  -- 2. ASSET CREATION: The Manufacturer creates the asset contract.
  debug "Step 2: Manufacturer creates the asset..."
  let assetId = "SN-987654"
  assetCid <- submit manufacturer do
    createCmd Asset with
      manufacturer = manufacturer
      assetId = assetId
      description = "High-Value Electronics Component"
      observers = [logisticsProvider, customsAgency, retailer]

  debug $ "Asset " <> assetId <> " created with CID: " <> show assetCid

  -- 3. SHIPMENT CREATION: The Manufacturer initiates a shipment for the asset.
  --    They are the initial custodian.
  debug "Step 3: Manufacturer initiates the shipment..."
  shipmentCid_M <- submit manufacturer do
    createCmd Shipment with
      assetCid = assetCid
      currentCustodian = manufacturer
      originalManufacturer = manufacturer
      destination = retailer
      isDelivered = False
      observers = [logisticsProvider, customsAgency] -- retailer is already destination

  debug $ "Initial shipment created with custodian " <> show manufacturer

  -- 4. HANDOVER 1: Manufacturer -> Logistics Provider
  debug "Step 4: Manufacturer transfers custody to Logistics Provider..."

  -- Manufacturer proposes the transfer
  proposalCid_M_L <- submit manufacturer do
    exerciseCmd shipmentCid_M ProposeCustodyTransfer with newCustodian = logisticsProvider

  -- Logistics provider accepts the transfer
  (shipmentCid_L, _) <- submit logisticsProvider do
    exerciseCmd proposalCid_M_L Accept

  debug $ "Custody successfully transferred to " <> show logisticsProvider

  -- 5. CHECKPOINT 1: Logistics Provider records a checkpoint.
  debug "Step 5: Logistics Provider records a departure checkpoint..."
  now <- getTime
  _ <- submit logisticsProvider do
    exerciseCmd shipmentCid_L RecordCheckpoint with
      location = "Central Distribution Hub"
      notes = Some "Shipment departed warehouse facility."
      timestamp = now

  debug "Logistics checkpoint recorded."

  -- 6. HANDOVER 2: Logistics Provider -> Customs Agency
  debug "Step 6: Logistics Provider transfers custody to Customs Agency..."

  -- Logistics provider proposes the transfer
  proposalCid_L_C <- submit logisticsProvider do
    exerciseCmd shipmentCid_L ProposeCustodyTransfer with newCustodian = customsAgency

  -- Customs agency accepts the transfer
  (shipmentCid_C, _) <- submit customsAgency do
    exerciseCmd proposalCid_L_C Accept

  debug $ "Custody successfully transferred to " <> show customsAgency

  -- 7. CHECKPOINT 2: Customs Agency records a clearance checkpoint.
  debug "Step 7: Customs Agency records a clearance checkpoint..."
  now2 <- getTime
  _ <- submit customsAgency do
    exerciseCmd shipmentCid_C RecordCheckpoint with
      location = "Port of Entry - Customs Zone"
      notes = Some "Inspection complete. Cleared for import."
      timestamp = now2

  debug "Customs checkpoint recorded."

  -- 8. HANDOVER 3: Customs Agency -> Retailer
  debug "Step 8: Customs Agency transfers custody to Retailer for final delivery..."

  -- Customs agency proposes the transfer
  proposalCid_C_R <- submit customsAgency do
    exerciseCmd shipmentCid_C ProposeCustodyTransfer with newCustodian = retailer

  -- Retailer accepts the transfer
  (shipmentCid_R, _) <- submit retailer do
    exerciseCmd proposalCid_C_R Accept

  debug $ "Custody successfully transferred to final destination: " <> show retailer

  -- 9. DELIVERY: Retailer marks the shipment as delivered.
  debug "Step 9: Retailer marks the shipment as delivered..."
  deliveredShipmentCid <- submit retailer do
    exerciseCmd shipmentCid_R MarkDelivered

  debug "Shipment has been marked as delivered."

  -- 10. VERIFICATION: Check the final state of the delivered shipment.
  deliveredShipment <- fetch deliveredShipmentCid
  assertMsg "Final custodian should be the retailer" (deliveredShipment.currentCustodian == retailer)
  assertMsg "Shipment should be marked as delivered" (deliveredShipment.isDelivered)

  -- Query for all checkpoints to verify the audit trail
  checkpoints <- query @Checkpoint manufacturer
  debug $ "Found " <> show (length checkpoints) <> " checkpoints on the ledger."
  assertMsg "There should be two checkpoints in total" (length checkpoints == 2)

  debug "SUCCESS: Full supply chain scenario completed and verified."
  return ()